import sys
from PyQt5.QtWidgets import QApplication, QMainWindow, QTabWidget, QTextEdit, QLineEdit, QPushButton, QLabel, QVBoxLayout, QWidget

class JackeryGUI(QMainWindow):
    def __init__(self):
        super().__init__()

        self.setWindowTitle("Jackery Studio")
        self.setGeometry(100, 100, 800, 600)

        # Create a QTabWidget
        tab_widget = QTabWidget()
        self.setCentralWidget(tab_widget)

        # Tab 1: Caleb Hub
        caleb_hub_tab = QWidget()
        layout = QVBoxLayout(caleb_hub_tab)

        chat_log = QTextEdit()
        chat_log.setReadOnly(True)
        layout.addWidget(chat_log)

        send_button = QPushButton("Send")
        line_edit = QLineEdit()
        layout.addWidget(line_edit)
        layout.addWidget(send_button)

        tab_widget.addTab(caleb_hub_tab, "CALEB Hub")

        # Placeholder Tabs
        for tab_name in ["Image Forge", "Video Motion VFX", "Audio Lab", "Settings"]:
            placeholder_tab = QWidget()
            layout = QVBoxLayout(placeholder_tab)
            label = QLabel(tab_name)
            layout.addWidget(label)
            tab_widget.addTab(placeholder_tab, tab_name)

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = JackeryGUI()
    window.show()
    sys.exit(app.exec_())